@model List<Lesson2.Models.Book>

<!DOCTYPE html>
<html>
<head>
    <title>Danh sách sách</title>
</head>
<body>
    <h2>Quản lý sách</h2>
    <p><a href="/Book/Create" style="font-weight:bold; color:blue;">+ Thêm sách mới</a></p>

    <table border="1" cellpadding="10" cellspacing="0">
        <thead>
            <tr style="background-color: #f2f2f2;">
                <th>Id</th>
                <th>Tên sách</th>
                <th>Giá</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Id</td>
                    <td>@book.Name</td>
                    <td>@book.Price $</td>
                    <td><a href="/Book/Detail/@book.Id">Chi tiết</a></td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>