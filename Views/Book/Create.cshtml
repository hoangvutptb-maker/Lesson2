@model Lesson2.Models.Book
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html>
<head>
    <title>Thêm sách</title>
</head>
<body>
    <h2>Thêm sách mới vào hệ thống</h2>

    @if (ViewBag.SuccessMessage != null)
    {
        <p style="color: green; font-weight: bold;">@ViewBag.SuccessMessage</p>
    }

    <form action="/Book/Create" method="post">
        <div>
            <label>Tên sách:</label><br />
            <input asp-for="Name" type="text" />
            <span asp-validation-for="Name" style="color: red;"></span>
        </div>
        <br />
        <div>
            <label>Giá sách:</label><br />
            <input asp-for="Price" type="number" step="0.01" />
            <span asp-validation-for="Price" style="color: red;"></span>
        </div>
        <br />
        <button type="submit">Thêm sách</button>
    </form>

    <br />
    <a href="/Book/Index"><- Quay lại danh sách</a>
</body>
</html>